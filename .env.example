# Безопасный образец. Настоящий токен сюда не вставлять.
BOT_TOKEN=PASTE_YOUR_BOTFATHER_TOKEN_HERE

# Необязательно: имя файла SQLite относительно папки проекта.
TASKS_DB=tasks.db

# ID находится между /d/ и /edit в ссылке Google Таблицы.
GOOGLE_SPREADSHEET_ID=PASTE_GOOGLE_SPREADSHEET_ID_HERE

# Точное имя вкладки внутри таблицы.
GOOGLE_SHEET_NAME=Задачи

# Локальный JSON-ключ сервисного аккаунта. Этот файл нельзя отправлять на GitHub.
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json

# Числовые Telegram ID владельцев через запятую. Узнать ID: команда /whoami.
TELEGRAM_OWNER_IDS=123456789
